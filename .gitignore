# =============================================================================
# nmatools .gitignore
# Based on github/gitignore R.gitignore + standard R package conventions
# =============================================================================

# ── R session artifacts ───────────────────────────────────────────────────────
.Rhistory
.Rapp.history
.RData
.Ruserdata

# ── R package build artifacts ─────────────────────────────────────────────────
*.tar.gz
*.Rcheck/
.Rbuildignore

# ── roxygen2 / documentation ──────────────────────────────────────────────────
# Do NOT ignore man/ or NAMESPACE — these are source-controlled in this package
# (roxygen2 generates them but they should be committed so install_github works
#  without requiring devtools on the user's machine)

# ── RStudio ───────────────────────────────────────────────────────────────────
*.Rproj
.Rproj.user/

# ── pkgdown site (generated, not source) ─────────────────────────────────────
docs/

# ── testthat snapshot artifacts ───────────────────────────────────────────────
tests/testthat/_snaps/

# ── Analysis outputs (generated by netmetawrap / run_nma_batch) ───────────────
outputs/

# ── Temporary / cache files ───────────────────────────────────────────────────
*.swp
*~
\#*\#

# ── OS metadata ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

